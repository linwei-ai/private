{%- liquid
  assign source = section.settings.content_source
  assign display_heading = ''
  assign display_body = ''

  if source == 'collection'
    assign display_body = collection.description
    if section.settings.show_heading
      assign display_heading = collection.title
    endif
  else
    assign display_heading = section.settings.heading
    assign display_body = section.settings.description
  endif

  assign show_section = false
  if display_body != blank or display_heading != blank
    assign show_section = true
  endif
  if request.design_mode
    assign show_section = true
  endif
-%}

{%- if show_section -%}
  {%- liquid
    assign cpd_color = section.settings.text_color
    assign cpd_r = cpd_color.red | default: 46
    assign cpd_g = cpd_color.green | default: 7
    assign cpd_b = cpd_color.blue | default: 53
  -%}
  {% style %}
    #shopify-section-{{ section.id }} {
      --cpd-text: {{ cpd_r }}, {{ cpd_g }}, {{ cpd_b }};
      --cpd-max: {{ section.settings.max_width }}px;
      --cpd-vmargin: {{ section.settings.vertical_margin }}px;
      --cpd-pad-mobile: {{ section.settings.padding_horizontal_mobile }}px;
    }
    #shopify-section-{{ section.id }} .collection-page-description__inner {
      max-width: var(--cpd-max);
      margin-left: auto;
      margin-right: auto;
      margin-top: 0;
      margin-bottom: var(--cpd-vmargin);
      padding: 0;
      box-sizing: border-box;
    }
    @media (max-width: 767.98px) {
      #shopify-section-{{ section.id }} .collection-page-description__inner {
        padding-left: var(--cpd-pad-mobile);
        padding-right: var(--cpd-pad-mobile);
      }
    }
    #shopify-section-{{ section.id }} .collection-page-description__heading {
      color: rgb(var(--cpd-text));
      font-weight: 700;
      margin: 0 0 1rem;
      line-height: 1.25;
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .collection-page-description__heading {
        font-size: {{ section.settings.heading_size_desktop }}px;
        text-align: {{ section.settings.heading_align_desktop }};
        margin-bottom: 1.2rem;
      }
    }
    @media (max-width: 767.98px) {
      #shopify-section-{{ section.id }} .collection-page-description__heading {
        text-align: {{ section.settings.heading_align_mobile }};
      }
    }
    #shopify-section-{{ section.id }} .collection-page-description__body,
    #shopify-section-{{ section.id }} .collection-page-description__body p {
      color: rgb(var(--cpd-text));
      font-weight: 400;
      font-size: {{ section.settings.body_size_mobile }}px;
      line-height: 1.45;
      margin: 0;
    }
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .collection-page-description__body,
      #shopify-section-{{ section.id }} .collection-page-description__body p {
        font-size: {{ section.settings.body_size_desktop }}px;
        text-align: {{ section.settings.body_align_desktop }};
      }
    }
    @media (max-width: 767.98px) {
      #shopify-section-{{ section.id }} .collection-page-description__body,
      #shopify-section-{{ section.id }} .collection-page-description__body p {
        text-align: {{ section.settings.body_align_mobile }};
      }
    }
    #shopify-section-{{ section.id }} .collection-page-description__body a {
      color: rgb(var(--cpd-text));
    }
    #shopify-section-{{ section.id }} .collection-page-description__body strong {
      font-weight: 700;
    }
    #shopify-section-{{ section.id }} .collection-page-description .read-more__toggle,
    #shopify-section-{{ section.id }} .collection-page-description .read-more__toggle .btn__text {
      font-size: {{ section.settings.body_size_mobile }}px !important;
      font-weight: 700 !important;
      color: rgb(var(--cpd-text)) !important;
    }
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} .collection-page-description .read-more__toggle,
      #shopify-section-{{ section.id }} .collection-page-description .read-more__toggle .btn__text {
        font-size: {{ section.settings.body_size_desktop }}px !important;
      }
      #shopify-section-{{ section.id }} .collection-page-description__read-more {
        text-align: {{ section.settings.body_align_desktop }};
      }
    }
    @media (max-width: 767.98px) {
      #shopify-section-{{ section.id }} .collection-page-description__read-more {
        text-align: {{ section.settings.body_align_mobile }};
      }
    }
  {% endstyle %}

  <div class="collection-page-description color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
    <div class="collection-page-description__inner">
      {%- if display_heading != blank -%}
        <{{ section.settings.heading_tag }} class="collection-page-description__heading">
          {%- if source == 'manual' -%}
            {{- display_heading -}}
          {%- else -%}
            {{- display_heading | escape -}}
          {%- endif -%}
        </{{ section.settings.heading_tag }}>
      {%- elsif request.design_mode and source == 'manual' -%}
        <p class="collection-page-description__heading">{{ 'sections.collection_page_description.placeholder_heading' | t }}</p>
      {%- endif -%}

      {%- if display_body != blank -%}
        <div class="collection-page-description__body-wrapper">
          {%- if section.settings.enable_read_more and section.settings.text_line_limit != 'none' -%}
            <read-more
              class="read-more__text collection-page-description__read-more"
              data-toggle-class="text-limit-{{ section.settings.text_line_limit }}"
              data-show-text="{{ 'accessibility.view_more' | t }}"
              data-hide-text="{{ 'accessibility.view_less' | t }}"
            >
              <div class="collection-page-description__body rte read-more__content">
                {{- display_body -}}
              </div>
              {%- assign read_label = 'accessibility.view_more' | t -%}
              {% render 'button',
                button_tag: 'button',
                additional_classes: 'read-more__toggle',
                button_label: read_label,
                button_style: section.settings.read_more_button_style,
                button_icon: section.settings.read_more_button_icon
              %}
            </read-more>
          {%- else -%}
            <div class="collection-page-description__body rte">
              {{- display_body -}}
            </div>
          {%- endif -%}
        </div>
      {%- elsif request.design_mode -%}
        <div class="collection-page-description__body rte">
          <p>{{ 'sections.collection_page_description.placeholder_body' | t }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collection-page-description.name",
  "tag": "section",
  "class": "section-collection-page-description",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collection-page-description.settings.header_content.content"
    },
    {
      "type": "select",
      "id": "content_source",
      "label": "t:sections.collection-page-description.settings.content_source.label",
      "options": [
        {
          "value": "collection",
          "label": "t:sections.collection-page-description.settings.content_source.options__collection.label"
        },
        {
          "value": "manual",
          "label": "t:sections.collection-page-description.settings.content_source.options__manual.label"
        }
      ],
      "default": "collection"
    },
    {
      "type": "paragraph",
      "content": "t:sections.collection-page-description.settings.collection_help.content"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "t:sections.collection-page-description.settings.show_heading.label",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.collection-page-description.settings.heading.label",
      "default": "Planchas para cabello",
      "visible_if": "{{ section.settings.content_source == 'manual' }}"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.collection-page-description.settings.description.label",
      "default": "<p>¿Buscas los mejores Eléctricos para el cabello en Colombia? Descubre nuestra selección de planchas profesionales, secadores, cepillos alisadores y más.</p>",
      "visible_if": "{{ section.settings.content_source == 'manual' }}"
    },
    {
      "type": "header",
      "content": "t:sections.collection-page-description.settings.header_layout.content"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.max_width.label",
      "default": 650
    },
    {
      "type": "range",
      "id": "vertical_margin",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.vertical_margin.label",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.padding_horizontal_mobile.label",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.collection-page-description.settings.text_color.label",
      "default": "#2E0735"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.collection-page-description.settings.header_heading.content"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:general.heading_tag.label",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "t:general.heading_tag.options__h1.label" },
        { "value": "h2", "label": "t:general.heading_tag.options__h2.label" },
        { "value": "h3", "label": "t:general.heading_tag.options__h3.label" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 18,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.heading_size_desktop.label",
      "default": 25
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.heading_size_mobile.label",
      "default": 15
    },
    {
      "type": "select",
      "id": "heading_align_desktop",
      "label": "t:sections.collection-page-description.settings.heading_align_desktop.label",
      "default": "center",
      "options": [
        { "value": "center", "label": "t:general.text_alignment.options__2.label" },
        { "value": "left", "label": "t:general.text_alignment.options__1.label" },
        { "value": "right", "label": "t:general.text_alignment.options__3.label" }
      ]
    },
    {
      "type": "select",
      "id": "heading_align_mobile",
      "label": "t:sections.collection-page-description.settings.heading_align_mobile.label",
      "default": "center",
      "options": [
        { "value": "center", "label": "t:general.text_alignment.options__2.label" },
        { "value": "left", "label": "t:general.text_alignment.options__1.label" },
        { "value": "right", "label": "t:general.text_alignment.options__3.label" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.collection-page-description.settings.header_body.content"
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.body_size_desktop.label",
      "default": 14
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "t:sections.collection-page-description.settings.body_size_mobile.label",
      "default": 14
    },
    {
      "type": "select",
      "id": "body_align_desktop",
      "label": "t:sections.collection-page-description.settings.body_align_desktop.label",
      "default": "center",
      "options": [
        { "value": "center", "label": "t:general.text_alignment.options__2.label" },
        { "value": "left", "label": "t:general.text_alignment.options__1.label" },
        { "value": "right", "label": "t:general.text_alignment.options__3.label" }
      ]
    },
    {
      "type": "select",
      "id": "body_align_mobile",
      "label": "t:sections.collection-page-description.settings.body_align_mobile.label",
      "default": "center",
      "options": [
        { "value": "center", "label": "t:general.text_alignment.options__2.label" },
        { "value": "left", "label": "t:general.text_alignment.options__1.label" },
        { "value": "right", "label": "t:general.text_alignment.options__3.label" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.collection-page-description.settings.header_read_more.content"
    },
    {
      "type": "checkbox",
      "id": "enable_read_more",
      "label": "t:sections.collection-page-description.settings.enable_read_more.label",
      "default": false
    },
    {
      "type": "select",
      "id": "text_line_limit",
      "label": "t:general.text_line_limit.label",
      "default": "none",
      "options": [
        { "value": "none", "label": "t:general.text_line_limit.options__none.label" },
        { "value": "1-line", "label": "t:general.text_line_limit.options__1.label" },
        { "value": "2-lines", "label": "t:general.text_line_limit.options__2.label" },
        { "value": "3-lines", "label": "t:general.text_line_limit.options__3.label" },
        { "value": "4-lines", "label": "t:general.text_line_limit.options__4.label" },
        { "value": "5-lines", "label": "t:general.text_line_limit.options__5.label" }
      ],
      "visible_if": "{{ section.settings.enable_read_more == true }}"
    },
    {
      "type": "select",
      "id": "read_more_button_style",
      "label": "t:general.button.button_style.label",
      "default": "btn--underline",
      "options": [
        { "value": "btn--primary", "label": "t:general.button.button_style.options__1.label" },
        { "value": "btn--secondary", "label": "t:general.button.button_style.options__2.label" },
        { "value": "btn--underline", "label": "t:general.button.button_style.options__4.label" },
        { "value": "btn--plain", "label": "t:general.button.button_style.options__7.label" }
      ],
      "visible_if": "{{ section.settings.enable_read_more == true }}"
    },
    {
      "type": "select",
      "id": "read_more_button_icon",
      "label": "t:general.button.button_icon.label",
      "default": "none",
      "options": [
        { "value": "none", "label": "t:general.button.button_icon.options__1.label" },
        { "value": "caret-right", "label": "t:general.button.button_icon.options__2.label" },
        { "value": "arrow-right", "label": "t:general.button.button_icon.options__3.label" }
      ],
      "visible_if": "{{ section.settings.enable_read_more == true }}"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-page-description.name",
      "category": "t:general.collection.name"
    }
  ]
}
{% endschema %}
