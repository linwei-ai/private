{{ 'collection-promo-banners.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection-promo-banners.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign visibility = section.settings.visibility | default: 'desktop_only'
  assign visibility_class = ''
  if visibility == 'desktop_only'
    assign visibility_class = 'promo-banners--desktop-only hidden md:block'
  elsif visibility == 'mobile_only'
    assign visibility_class = 'promo-banners--mobile-only md:hidden'
  endif

  assign cpb_sizes = '(max-width: 767px) 100vw, min(100vw, ' | append: settings.page_width | append: 'px)'

  assign show = false
  if section.blocks.size > 0
    assign show = true
  endif
  if request.design_mode
    assign show = true
  endif
-%}

{%- if show -%}
  {% style %}
    .section-{{ section.id }} {
      --cpb-pad-inline: {{ section.settings.padding_inline }}px;
      --cpb-gap-desktop: {{ section.settings.gap_desktop }}px;
      --cpb-gap-mobile: {{ section.settings.gap_mobile }}px;
    }
  {% endstyle %}

  <div
    class="section section-{{ section.id }} section--padding collection-promo-banners color-{{ section.settings.color_scheme }} {{ visibility_class }}"
    style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  >
    <div class="collection-promo-banners__container page-width page-width--{{ section.settings.container }}">
      <div class="collection-promo-banners__inner" style="padding-left: var(--cpb-pad-inline); padding-right: var(--cpb-pad-inline);">
        {%- if section.blocks.size == 0 and request.design_mode -%}
          <p class="m-0 text-subtext">{{ 'sections.collection-promo-banners.empty' | t }}</p>
        {%- else -%}
          <collection-promo-banners
            class="collection-promo-banners__slider block relative swiper-show-nav-on-hover"
            data-section-id="{{ section.id }}"
            data-slides-desktop="{{ section.settings.slides_desktop }}"
            data-slides-mobile="{{ section.settings.slides_mobile }}"
            data-gap-desktop="{{ section.settings.gap_desktop }}"
            data-gap-mobile="{{ section.settings.gap_mobile }}"
          >
            <div class="collection-promo-banners__track swiper-wrapper">
              {%- for block in section.blocks -%}
                {%- if block.type == 'banner' -%}
                  <div
                    class="swiper-slide collection-promo-banners__slide"
                    {{ block.shopify_attributes }}
                    data-index="{{ forloop.index0 }}"
                  >
                    {%- liquid
                      assign img_d = block.settings.image
                      assign img_m = block.settings.image_mobile
                      if img_m == blank
                        assign img_m = img_d
                      endif
                      assign link_url = block.settings.link
                      assign img_alt = block.settings.image_alt | default: img_d.alt | escape
                    -%}
                    {%- if link_url != blank -%}
                      <a href="{{ link_url }}" class="collection-promo-banners__link block media-wrapper blocks-radius overflow-hidden focus-inset">
                    {%- else -%}
                      <div class="collection-promo-banners__link block media-wrapper blocks-radius overflow-hidden">
                    {%- endif -%}
                    {%- if img_d != blank -%}
                      <picture>
                        {%- if block.settings.image_mobile != blank -%}
                          <source
                            media="(max-width: 767px)"
                            srcset="{{ block.settings.image_mobile | image_url: width: 400 }} 400w, {{ block.settings.image_mobile | image_url: width: 600 }} 600w, {{ block.settings.image_mobile | image_url: width: 800 }} 800w"
                            width="{{ block.settings.image_mobile.width }}"
                            height="{{ block.settings.image_mobile.height }}"
                          >
                        {%- endif -%}
                        {{
                          img_d
                          | image_url: width: img_d.width
                          | image_tag:
                            loading: 'lazy',
                            class: 'motion-reduce w-full h-full object-cover',
                            widths: '400,600,800,1000,1200,1400,1600',
                            sizes: cpb_sizes,
                            alt: img_alt
                        }}
                      </picture>
                    {%- else -%}
                      <div class="collection-promo-banners__placeholder blocks-radius bg-none" style="aspect-ratio: 21/9;">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                    {%- if link_url != blank -%}
                      </a>
                    {%- else -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if section.blocks.size > 1 -%}
              <div class="swiper-controls swiper-controls--nav-floating md:flex color-{{ section.settings.carousel_color_scheme }}">
                <button
                  type="button"
                  class="swiper-button swiper-button--drop-shadow swiper-button-prev btn"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                >
                  <span class="btn__text">{% render 'icon-caret-left', size: 'small' %}</span>
                </button>
                <button
                  type="button"
                  class="swiper-button swiper-button--drop-shadow swiper-button-next btn"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                >
                  <span class="btn__text">{% render 'icon-caret-right', size: 'small' %}</span>
                </button>
              </div>
            {%- endif -%}
          </collection-promo-banners>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collection-promo-banners.name",
  "tag": "section",
  "class": "section-collection-promo-banners",
  "enabled_on": {
    "templates": ["collection"]
  },
  "max_blocks": 24,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.collection-promo-banners.settings.intro.content"
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "t:sections.collection-promo-banners.settings.visibility.label",
      "default": "desktop_only",
      "options": [
        {
          "value": "desktop_only",
          "label": "t:sections.collection-promo-banners.settings.visibility.options__desktop.label"
        },
        {
          "value": "mobile_only",
          "label": "t:sections.collection-promo-banners.settings.visibility.options__mobile.label"
        },
        {
          "value": "both",
          "label": "t:sections.collection-promo-banners.settings.visibility.options__both.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "container",
      "label": "t:general.container.label",
      "default": "fixed",
      "options": [
        { "value": "full", "label": "t:general.container.options__full.label" },
        { "value": "fixed", "label": "t:general.container.options__fixed.label" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "carousel_color_scheme",
      "label": "t:sections.collection-promo-banners.settings.carousel_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.collection-promo-banners.settings.header_spacing.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.padding.top.label",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.padding.bottom.label",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_inline",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "t:sections.collection-promo-banners.settings.padding_inline.label",
      "default": 0,
      "info": "t:sections.collection-promo-banners.settings.padding_inline.info"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "t:sections.collection-promo-banners.settings.gap_desktop.label",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "t:sections.collection-promo-banners.settings.gap_mobile.label",
      "default": 12
    },
    {
      "type": "header",
      "content": "t:sections.collection-promo-banners.settings.header_carousel.content"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "t:sections.collection-promo-banners.settings.slides_desktop.label",
      "default": 3,
      "info": "t:sections.collection-promo-banners.settings.slides_visible.info"
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "t:sections.collection-promo-banners.settings.slides_mobile.label",
      "default": 1,
      "info": "t:sections.collection-promo-banners.settings.slides_visible.info"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "t:sections.collection-promo-banners.blocks.banner.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collection-promo-banners.blocks.banner.settings.image_desktop.label"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.collection-promo-banners.blocks.banner.settings.image_mobile.label",
          "info": "t:sections.collection-promo-banners.blocks.banner.settings.image_mobile.info"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "t:sections.collection-promo-banners.blocks.banner.settings.image_alt.label",
          "info": "t:sections.collection-promo-banners.blocks.banner.settings.image_alt.info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.collection-promo-banners.blocks.banner.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-promo-banners.name",
      "category": "t:general.collection.name",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}
